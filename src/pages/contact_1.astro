---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import RFQForm from '@components/react/RFQForm';
import { Image } from 'astro:assets';
import { FileText, Clock, Shield, CheckCircle2, Phone, Mail, MessageCircle, Award, TrendingUp, Users } from 'lucide-react';
import rfqBgImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import warehouseImg from '@assets/photo-1563013544-824ae1b704d3.jpg';
---

<BaseLayout title="Request a Quote - Get Started Today">
  <!-- Hero Section with Professional Image -->
  <section class="relative h-[500px] md:h-[600px] flex items-center overflow-hidden">    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image 
        src={rfqBgImg}
        alt="Professional logistics and supply chain management"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />      <div class="absolute inset-0" overlay-brown-burgundy></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-gradient-warm-horizontal text-white text-sm font-semibold rounded-full shadow-lg animate-fadeInUp">
          <FileText className="w-4 h-4 mr-2" />
          Get Your Custom Quote Today
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp" style="animation-delay: 0.1s">
          Request a <span class="gradient-text-span">Quote</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.2s">
          Get a customized quote tailored to your specific logistics and manufacturing needs. 
          We typically respond within 24 hours with a comprehensive proposal.
        </p>        <!-- Quick Stats -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6 pt-8 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.3s">
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold mb-1 gradient-text-warm">24hr</div>
            <div class="text-sm text-slate-300 transition-colors hover:text-light-tan-dark">Response Time</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold mb-1 gradient-text-warm">500+</div>
            <div class="text-sm text-slate-300 transition-colors hover:text-light-tan-dark">Happy Clients</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold mb-1 gradient-text-warm">99.9%</div>
            <div class="text-sm text-slate-300 transition-colors hover:text-light-tan-dark">On-Time Rate</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave separator -->
    <!-- <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div> -->
  </section>

  <!-- Main Form Section -->
  <Section class="bg-neutral-400">
      <div class="flex h-screen items-center justify-center ">
              <iframe src="https://docs.google.com/forms/d/e/1FAIpQLScDacbw1Bo7yg6wvpBRsQuLlXbn-h8lW7F4HDNY6XgFNaLHpA/viewform?embedded=true" width="640" height="1123" frameborder="0" marginheight="0" marginwidth="0">Loading…</iframe>
      </div>
      <a href="https://forms.gle/A4D25asZgPLvw8QF6"> contact link </a>
  </Section>
</BaseLayout>

<style>
  .gradient-text-span {
    background: linear-gradient(to right, #e1b486, #8d7051, #e1b486);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>


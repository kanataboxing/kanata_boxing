---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import CapabilityAccordion from '../components/react/CapabilityAccordion';
import { Image } from 'astro:assets';
import ImageReveal from '../components/react/ImageReveal';

import taekwondoImg from '@assets/kick-1.jpg';
import manufacturingImg from '@assets/hapkido-2.jpg';
import transportationImg from '@assets/photo-1601584115197-04ecc0da31d7.jpg';
import supplyChainImg from '@assets/photo-1460925895917-afdab827c52f.jpg';
import valueAddedServicesImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import technologyIntegrationImg from '@assets/photo-1558494949-ef010cbdcc31.jpg';
import heroBgImg from '@assets/martial-arts-1.jpg';
import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';

const capabilities = [
{
title: 'Taekwondo',
description: 'Taekwondo is a dynamic Korean martial art with roots tracing back over 2,000 years to ancient Korean warrior traditions, with modern Taekwondo emerged post-World War II. Taekwondo stands out for its high-flying, fast, and diverse arsenal of kicks, making it a spectacle of speed, precision, and physical control. Beyond the physical techniques, Taekwondo emphasizes the tenets of Courtesy, Integrity, Perseverance, Self-Control, and Indomitable Spirit.',
icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
    d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
</svg>`,
image: taekwondoImg,
features: [
'Focus on striking',
'Powerful, Dynamic kicks',
'Rapid Footwork and mobility',
]
},
{
title: 'Hapkido',
description: 'Hapkido, is a highly comprehensive Korean martial art that developed in the mid-20th century, by combining Korean and Japanese kartial arts. What distinguishes Hapkido focuses on self-defence and using the opponent’s force against them. Unlike the external, striking focus of Taekwondo or the rigid grappling of Judo, Hapkido is a practical, complete self-defense system. Its holistic nature makes it one of the most versatile and effective martial arts for immediate, real-world application.',
icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
    d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
</svg>`,
image: manufacturingImg,
features: [
'Joint Locks',
'Throws and Falls',
'Weapon Defense and Offense',
]
}
];
---

<BaseLayout title="Master Ken - Adult Programs">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image src={heroBgImg} alt="Modern logistics and manufacturing capabilities" class="w-full h-full object-cover"
        width={2070} height={1380} />
      <div class="absolute inset-0 bg-linear-to-r from-stone-900/95 via-stone-900/80 to-stone-900/50"></div>
    </div> <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <!-- <div class="inline-flex items-center px-4 py-2 mb-6 text-white text-sm font-semibold rounded-full shadow-lg bg-gradient-burgundy">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          Comprehensive Solutions
        </div> -->

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Adult Programs
          <!-- <span class="cap-gradient-text">
            Capabilities
          </span> -->
        </h1>

        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
          Learn from the rich tradition of Korean Martial Arts, such as Taekwondo and Hapkido.
        </p>
      </div>
    </div>
  </section>

  <style>
    .cap-gradient-text {
      background: linear-gradient(135deg, #9f3434 0%, #8d7051 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: inline-block;
    }
  </style>

  <!-- Main Capabilities -->
  <Section background="gray">
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-justify">

        <p class="text-xl md:text-2xl text-slate-800 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
        Wanting to get in better shape but looking for a new routine? </p>
        
        <p>Discover what Martial Artists have known for
        centuries, training goes beyond getting physical benefits and getting in shape but will help improve your mental
        wellbeing.</p>

        

        <ul style="text-indent: 40px; padding-top:10px;">
          <li>&#8227 Get Fitter</li>
          <li>&#8227 Feel Calmer</li>
          <li>&#8227 Become Less Stressed</li>
          <li>&#8227 Increase overall happiness</li>
        </ul>

        <br>
        <p>Our Adult Martial Arts Program in unrivalled because it isn't about stepping onto the training
        area and being one of many but here you will be guided every step of your journey by one of
        the area's most experience instructors. Our Beginner friendly martial arts you can train in:
        </p>

        <ul style="text-indent: 40px; padding-top:10px;">
          <li>&#8227 Boxing</li>
          <li>&#8227 Hapkido (Korean MMA)</li>
          <li>&#8227 Taekwondo</li>
        </ul>

        <br>
        Or in a program that blends all three where a specific program is tailored around your abilities
        and interests to maximize your fitness goals. Whether it's learning self defense, getting in shape while
        discovering your own “rocky”
        moments, contact us to start your journey.
      </div>
    </div>

  </Section>
  <!-- Process Section -->
  <Section background="white">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 text-sm font-semibold rounded-full bg-light-tan-dark text-brown">
        Our Approach
      </div>
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-brown">
        Training with master Ken
        <!-- Our <span class="gradient-text">Process</span> -->
      </h2>
      <p class="text-xl max-w-3xl mx-auto leading-relaxed text-brown-light">
        All Sessions presonally instructed by Master Ken, enabling him to monitor and enhance your development.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
      {
      step: '01',
      title: 'Consultation',
      description: 'Understanding your unique goals and challenges',
      icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>`
      },
      {
      step: '02',
      title: 'Planning',
      description: 'Design customized solutions tailored to your needs',
      icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>`
      },
      {
      step: '03',
      title: 'Implementation',
      description: 'Execute with precision and attention to detail',
      icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>`
      },
      {
      step: '04',
      title: 'Optimization',
      description: 'Continuous improvement and performance monitoring',
      icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>`
      } ].map((process, index) => (
      <Card hover class="text-center animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
        <div class={`flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-xl text-white shadow-lg
          group-hover:scale-110 transition-transform ${index % 2===0 ? 'bg-gradient-burgundy' : 'bg-gradient-tan' }`}>
          <div set:html={process.icon} />
        </div>
        <div class="text-3xl font-bold gradient-text mb-2">{process.step}</div>
        <h3 class="text-xl font-bold mb-3 text-brown">{process.title}</h3>
        <p class="leading-relaxed text-brown-light">{process.description}</p>
      </Card>
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-32 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image src={ctaBgImg} alt="Modern warehouse operations" class="w-full h-full object-cover" width={2070}
        height={1380} />
      <div class="absolute inset-0 bg-gradient-earth"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div
          class="inline-block px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          Get Started Today
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Ready to Start Training?
          <!-- <span class="cap-cta-gradient">AstroFlow</span>? -->
        </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-12 max-w-2xl mx-auto leading-relaxed">
          Let's discuss a training plan that best suits your goals and needs.
        </p>

        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href="/master_ken/contact" size="lg">
            Contact
          </Button>
          <!-- <Button href="/documentation" size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
            View Documentation
          </Button> -->
        </div>
      </div>
    </div>
  </section>

  <style>
    .cap-cta-gradient {
      background: linear-gradient(135deg, #9f3434 0%, #8d7051 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: inline-block;
    }
  </style>
</BaseLayout>
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import ImageReveal from '../../components/react/ImageReveal';
import { Image } from 'astro:assets';

import gettingStartedImg from '@assets/photo-1451187580459-43490279c0fa.jpg';
import onboardingChecklistImg from '@assets/photo-1486406146926-c627a92ad1ab.jpg';
import serviceOverviewImg from '@assets/photo-1550751827-4bd374c3f58b.jpg';
import technicalDocumentationImg from '@assets/photo-1454165804606-c3d57bc86b40.jpg';
import operationsManualImg from '@assets/photo-1521737604893-d14cc237f11d.jpg';

import boxing_icon from '@assets/boxing_gloves.png';

import formsTemplatesImg from '@assets/boxing_main.jpg';
import heroBgImg from '@assets/boxing_main.png';
import Timeline from '../../components/Timeline.astro';

---

<BaseLayout title="Documentation - Resources & Guides">
  <!-- Hero Section with Professional Background -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={heroBgImg}
        alt="Professional documentation and resources"
        class="w-full h-full object-contain"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(59,130,246,0.1),transparent_70%)]"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  

  <!-- FAQ Section -->
  <Section background="white" id="faq">
    <div class="text-center mb-16">
      <!-- <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Support
      </div> -->
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        About Boxing
        <!-- Frequently Asked <span class="gradient-text">Questions</span> -->
      </h2>
    </div>
      <div class="text-justify mb-16">
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      Master Ken started training in Boxing just over 20 years ago at Motor City Boxing in Oshawa with Don Nelson.  Over the years, he has trained at various other gyms including private sessions at Tri Star in Montreal and with Howard Grant.  He still actively trains and currently holds his Level one NCCP coaching certification through boxing Canada.
      </p> 
      <br>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      Though boxing is the art where you will find early technical success as a beginner, it does have the stigma about “brain Trauma” due to repetitive punches to the head.  With just over 20 years’ experience training/coaching boxing, and over 40 teaching children, Master Ken has developed this dynamic boxing program where you will gain all the benefits of boxing in a dynamic, safe and fun environment without the inherent risks.
      </p>

      <br>

      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      For children, training in boxing has been proven to increase their cognitive ability, memory, stabilize their mood by the mental and physical demands of the workouts.  This increases their focus and concentration while having a great time training all the while building their mental, physical and emotional strength. 
      <a href= "/master_ken/blog"> Click here for the benefits of boxing for children.
      <Image 
        src={boxing_icon}
        alt="boxing gloves"
        class="inline h-8 w-8"
        width={32}
        height={32}
      />
      </a>

      <br>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      For adults looking to get in shape, burn off some stress from work, increase your physical wellbeing and mental clarity without having to get bogged down in the technicality of the other martial arts?  Then boxing is for you.
      </p>

      <br>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      Whether you are looking for a program for your child or yourself that will make a difference in school, at home, to get in shape and become a calmer, stronger more confident version of yourself while having a lot of fun in Kanata/Stittsville’s only pure boxing program and be in a welcoming, exciting and fun environment?  Then this is the program for you!  Click here for your free consultation to get started NOW!
      </p>
      <br>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      </p>
    </div>

    
  </Section>


</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  
  details[open] summary {
    margin-bottom: 0.5rem;
  }
</style>

---
import FeatureShowcase from '../react/FeatureShowcase';
---

<section class="py-24 bg-neutral-400">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
    <FeatureShowcase client:load />
    
    <!-- Bottom CTA -->    <div class="text-center mt-16">
      <a 
        href="https://forms.gle/A4D25asZgPLvw8QF6" 
        class="inline-flex items-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:shadow-xl transition-all group bg-gradient-burgundy"
      >
        Start Training Now
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

